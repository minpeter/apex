{
  "name": "oh-my-openclaw",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target bun --format esm",
    "build:compile": "bun build src/cli.ts --compile --bytecode --outfile dist/oh-my-openclaw",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "json5": "^2.2.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "typescript": "^5.9.3"
  }
}

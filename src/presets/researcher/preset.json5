{
  name: 'researcher',
  description: 'Research-focused setup with web tools and conservative model',
  version: '1.0.0',
  author: 'oh-my-openclaw',
  tags: ['research', 'web', 'conservative'],
  builtin: true,
  config: {
    identity: {
      name: 'ResearchBot',
      theme: 'research assistant',
      emoji: '🔬',
    },
    agents: {
      defaults: {
        model: {
          primary: 'anthropic/claude-haiku-4-5',
        },
      },
    },
    tools: {
      allow: ['read', 'web_search', 'summarize'],
    },
  },
  workspaceFiles: ['AGENTS.md', 'SOUL.md'],
}
